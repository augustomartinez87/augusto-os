{
  "name": "orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx --env-file=.env src/index.ts",
    "dev": "tsx --env-file=.env --watch src/index.ts",
    "approve": "tsx --env-file=.env src/index.ts --approve",
    "bot": "tsx --env-file=.env src/bot.ts",
    "sync": "tsx --env-file=.env src/sync.ts",
    "test": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "execa": "^9.3.0",
    "lowdb": "^7.0.1",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
